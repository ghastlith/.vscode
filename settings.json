{
  // editor
  "editor.detectIndentation": false,
  "editor.tabSize": 2,
  "editor.renderWhitespace": "all",
  "editor.codeLens": false,
  "workbench.browser.openLocalhostLinks": false,

  // theme
  "workbench.colorTheme": "Dark Modern",
  "zenMode.hideLineNumbers": false,
  "zenMode.hideStatusBar": false,
  "zenMode.restore": false,

  // file formatting
  "editor.formatOnSave": true,
  "editor.insertSpaces": true,
  "files.trimFinalNewlines": true,
  "files.insertFinalNewline": true,
  "files.trimTrailingWhitespace": true,

  // disable specific file formatting
  "[java][svelte][typescript]": {
    "editor.formatOnSave": false
  },

  // git
  "diffEditor.ignoreTrimWhitespace": false,
  "scm.alwaysShowRepositories": true,
  "gitlens.codeLens.authors.enabled": false,

  // java
  "[java]": {
    "editor.defaultFormatter": "redhat.java"
  },
  "java.configuration.updateBuildConfiguration": "automatic",
  "java.test.config": {
    "vmArgs": ["-XX:+EnableDynamicAgentLoading"]
  },
  "spring-boot.ls.problem.application-properties.PROP_UNKNOWN_PROPERTY": "IGNORE",

  // svelte
  "[svelte]": {
    "editor.defaultFormatter": "svelte.svelte-vscode"
  },
  "svelte.enable-ts-plugin": true,

  // other file types
  "[typescript]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[json]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[jsonc]": { "editor.defaultFormatter": "esbenp.prettier-vscode" },
  "[svg]": { "editor.defaultFormatter": "jock.svg" },

  // extensions
  "thunder-client.sidebar.layout": "compact",

  // disable ai
  "chat.agent.enabled": false,
  "chat.disableAIFeatures": true,
  "git.addAICoAuthor": "off",
  "workbench.secondarySideBar.defaultVisibility": "hidden"
}
